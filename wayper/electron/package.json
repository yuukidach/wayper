{
  "name": "wayper",
  "version": "0.14.1",
  "productName": "Wayper",
  "description": "Wayper Electron GUI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:backend": "cd ../.. && uv run pyinstaller --clean wayper.spec",
    "dist": "npm run build:backend && ./node_modules/.bin/electron-builder"
  },
  "build": {
    "appId": "com.wayper.app",
    "icon": "../../assets/icon.icns",
    "extraResources": [
      {
        "from": "../../dist/wayper-backend",
        "to": "wayper-backend"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  }
}
