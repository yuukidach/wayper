{
  "name": "wayper-electron",
  "version": "1.0.0",
  "description": "Wayper Electron GUI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.wayper.electron",
    "mac": {
      "target": "dmg",
